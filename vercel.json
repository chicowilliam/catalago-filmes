{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm --prefix catalog-projeto run build",
  "outputDirectory": "catalog-projeto/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/data/**",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

# ==========================
# Configuracoes do Servidor
# ==========================
NODE_ENV=development
PORT=3000

# ==========================
# Sessao Express
# ==========================
# Gere um secret forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ==========================
# Credenciais Admin
# ==========================
ADMIN_USERNAME=admin
# Use hash bcrypt em producao: node -e "require('bcryptjs').hash('suaSenha', 12).then(h => console.log(h))"
ADMIN_PASSWORD=

# ==========================
# TMDB API (obrigatorio pelo menos um)
# ==========================
# Obtenha em: https://www.themoviedb.org/settings/api
TMDB_BEARER_TOKEN=
TMDB_API_KEY=

# ==========================
# Catalogo (opcionais)
# ==========================
# CATALOG_LIMIT=20        # 1-40
# TMDB_TIMEOUT_MS=8000    # 1000-15000
# TMDB_AUTO_PAGES=1       # 1-5

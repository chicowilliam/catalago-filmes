{
  "name": "catalago-filmes",
  "version": "1.0.0",
  "description": "Catálogo de filmes com Node.js",
  "main": "server.js",
  "scripts": {
    "postinstall": "npm --prefix catalog-projeto install",
    "start": "npm --prefix catalog-projeto run preview",
    "dev": "npm --prefix catalog-projeto run dev",
    "preview": "npm --prefix catalog-projeto run preview",
    "dev:api": "node ./node_modules/nodemon/bin/nodemon.js server.js",
    "start:api": "node server.js",
    "build:frontend": "npm --prefix catalog-projeto run build",
    "build": "npm run build:frontend",
    "test": "node ./node_modules/jest/bin/jest.js",
    "test:frontend": "npm --prefix catalog-projeto run test:run",
    "test:frontend:coverage": "npm --prefix catalog-projeto run test:coverage",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node ./node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.17.0",
    "helmet": "^8.1.0",
    "joi": "^17.9.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "jsdom": "^29.0.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
